{
  "manifest_version": 3,
  "name": "Moodboard",
  "version": "0.1.0",
  "description": "Local AI moodboard — spatial canvas with Ollama-powered scouts in your Chrome.",
  "permissions": [
    "tabs",
    "tabGroups",
    "scripting",
    "storage",
    "contextMenus",
    "alarms",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "chrome_url_overrides": {
    "newtab": "src/newtab/index.html"
  },
  "options_page": "src/options/index.html",
  "action": {
    "default_title": "Moodboard",
    "default_icon": {
      "16": "public/icon16.png",
      "48": "public/icon48.png",
      "128": "public/icon128.png"
    }
  },
  "icons": {
    "16": "public/icon16.png",
    "48": "public/icon48.png",
    "128": "public/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"],
      "run_at": "document_idle"
    }
  ]
}
